{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Compile CLI",
			"type": "shell",
			"group": "build",
			"command": "darklua process ./cli/Init.luau Out/Bundle.luau;darklua minify Out/Bundle.luau Out/Bundle.luau;lune build Out/Bundle.luau -o lupa.exe",
			"isBackground": true,
			"presentation": {
				"reveal": "never",
				"revealProblems": "never",
				"panel": "dedicated"
			}
		},
		{
			"label": "Compile Extension",
			"type": "shell",
			"command": "pnpm run compile",
			"options": {
				"cwd": "${workspaceFolder}/Extension/lupa",
				"env": {
					"PATH": "${env:PATH}"
				}
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$tsc",
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"focus": false,
				"showReuseMessage": false
			}
		},
		{
			"label": "Watch Extension",
			"type": "shell",
			"command": "pnpm run watch",
			"options": {
				"cwd": "${workspaceFolder}/Extension/lupa"
			},
			"isBackground": true,
			"problemMatcher": "$tsc-watch",
			"presentation": {
				"reveal": "never",
				"panel": "dedicated"
			}
		},
		{
			"label": "Benchmark Dump",
			"type": "shell",
			"command": "darklua process ./cli/Init.luau Out/Bundle.luau; lune run Out/Bundle.luau benchmark",
			"group": "test",
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"focus": true,
				"showReuseMessage": false
			}
		},
		{
			"label": "Install Extension Locally",
			"type": "shell",
			"command": "pnpm run install-local",
			"options": {
				"cwd": "${workspaceFolder}/Extension/lupa",
				"env": {
					"PATH": "${env:PATH}"
				}
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"focus": true,
				"showReuseMessage": false
			}
		}
	]
}
