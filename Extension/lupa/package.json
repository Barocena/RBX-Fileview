{
  "name": "lupa",
  "displayName": "Lupa",
  "description": "Human-readable viewer for Roblox place and model files.",
  "version": "0.0.12",
  "publisher": "lupa",
  "license": "MPL-2.0",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCustomEditor:lupa.roblox",
    "workspaceContains:**/*.rbxm",
    "workspaceContains:**/*.rbxl",
    "onCommand:lupa.openWith"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "lupa.roblox",
        "displayName": "Lupa",
        "selector": [
          {
            "filenamePattern": "*.rbxl"
          },
          {
            "filenamePattern": "*.rbxlx"
          },
          {
            "filenamePattern": "*.rbxm"
          },
          {
            "filenamePattern": "*.rbxmx"
          },
          {
            "filenamePattern": "**/*.rbxl"
          },
          {
            "filenamePattern": "**/*.rbxlx"
          },
          {
            "filenamePattern": "**/*.rbxm"
          },
          {
            "filenamePattern": "**/*.rbxmx"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "lupa.refresh",
        "title": "Lupa: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "lupa.copyDump",
        "title": "Lupa: Copy Dump Output"
      },
      {
        "command": "lupa.openWith",
        "title": "Lupa: Open with Lupa Editor"
      },
      {
        "command": "lupa.selectForCompare",
        "title": "Lupa: Select for Compare"
      },
      {
        "command": "lupa.compareWithSelected",
        "title": "Lupa: Compare with Selected"
      },
      {
        "command": "lupa.compareWith",
        "title": "Lupa: Compare with..."
      },
      {
        "command": "lupa.compareActiveWith",
        "title": "Lupa: Compare Active File With..."
      },
      {
        "command": "lupa.openGitChanges",
        "title": "Lupa: Open Git Changes",
        "icon": "$(git-compare)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "lupa.refresh",
          "when": "lupa.dumpActive",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "lupa.refresh",
          "when": "lupa.dumpActive"
        },
        {
          "command": "lupa.copyDump",
          "when": "lupa.dumpActive"
        },
        {
          "command": "lupa.openWith",
          "when": "resourceExtname == .rbxl || resourceExtname == .rbxlx || resourceExtname == .rbxm || resourceExtname == .rbxmx"
        },
        {
          "command": "lupa.compareActiveWith",
          "when": "lupa.dumpActive"
        },
        {
          "command": "lupa.compareWith",
          "when": "resourceExtname == .rbxl || resourceExtname == .rbxlx || resourceExtname == .rbxm || resourceExtname == .rbxmx"
        },
        {
          "command": "lupa.selectForCompare",
          "when": "resourceExtname == .rbxl || resourceExtname == .rbxlx || resourceExtname == .rbxm || resourceExtname == .rbxmx"
        },
        {
          "command": "lupa.compareWithSelected",
          "when": "lupa.compareSourceSet && (resourceExtname == .rbxl || resourceExtname == .rbxlx || resourceExtname == .rbxm || resourceExtname == .rbxmx)"
        },
        {
          "command": "lupa.openGitChanges",
          "when": "scmResourceExtname == .rbxl || scmResourceExtname == .rbxlx || scmResourceExtname == .rbxm || scmResourceExtname == .rbxmx"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "lupa.openGitChanges",
          "when": "scmResourceExtname == .rbxl || scmResourceExtname == .rbxlx || scmResourceExtname == .rbxm || scmResourceExtname == .rbxmx",
          "group": "navigation@1"
        }
      ],
      "explorer/context": [
        {
          "command": "lupa.openWith",
          "when": "resourceExtname == .rbxl || resourceExtname == .rbxlx || resourceExtname == .rbxm || resourceExtname == .rbxmx",
          "group": "navigation"
        },
        {
          "command": "lupa.selectForCompare",
          "when": "resourceExtname == .rbxl || resourceExtname == .rbxlx || resourceExtname == .rbxm || resourceExtname == .rbxmx",
          "group": "1_diff@1"
        },
        {
          "command": "lupa.compareWithSelected",
          "when": "lupa.compareSourceSet && (resourceExtname == .rbxl || resourceExtname == .rbxlx || resourceExtname == .rbxm || resourceExtname == .rbxmx)",
          "group": "1_diff@2"
        },
        {
          "command": "lupa.compareWith",
          "when": "resourceExtname == .rbxl || resourceExtname == .rbxlx || resourceExtname == .rbxm || resourceExtname == .rbxmx",
          "group": "1_diff@3"
        }
      ]
    },
    "configuration": {
      "title": "Lupa",
      "properties": {
        "lupa.cliPath": {
          "type": "string",
          "default": "lupa",
          "description": "Path to the lupa CLI executable. Defaults to lupa on PATH, or lupa.exe in the workspace root."
        },
        "lupa.dumpFormat": {
          "type": "string",
          "enum": [
            "yaml",
            "tree"
          ],
          "default": "yaml",
          "description": "Output format passed to lupa dump."
        },
        "lupa.maxDepth": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "description": "Optional max traversal depth for lupa dump."
        },
        "lupa.includeFullProperties": {
          "type": "boolean",
          "default": false,
          "description": "Include default-valued properties in dump output."
        },
        "lupa.setupGitDiff": {
          "type": "boolean",
          "default": true,
          "description": "Configure git textconv so Source Control diffs show Lupa YAML instead of binary."
        },
        "lupa.updateGitAttributes": {
          "type": "boolean",
          "default": true,
          "description": "Add Lupa diff driver lines to .gitattributes when missing in the workspace."
        },
        "lupa.openByDefault": {
          "type": "boolean",
          "default": true,
          "description": "When a .rbxm file is opened from disk, automatically show the read-only Lupa YAML text view."
        },
        "lupa.openDiffForChangedFiles": {
          "type": "boolean",
          "default": true,
          "description": "When a changed Roblox file is opened from Source Control, open the Lupa HEAD vs working tree diff. Explorer opens always show a single-file view."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\" && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "open-dev-host": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/open-dev-host.ps1",
    "package-vsix": "pnpm run compile && pnpm exec vsce package --no-dependencies --allow-missing-repository",
    "install-local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/install-local.ps1",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.105.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
